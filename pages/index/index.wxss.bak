/* index.wxss */
page {
  font-family: "DIN Alternate", "Futura", "PingFang SC", sans-serif;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background: #000000;
  color: #ffffff;
}

.page {
  width: 100vw;
  height: 100vh;
  padding: 0;
  background: #000000;
  box-sizing: border-box;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: stretch;
}

.top-bar {
  width: 100%;
  height: 15vh;
  padding: 0 2vw;
  border: 1rpx solid #ffffff;
  background: #000000;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.top-left,
.top-right {
  width: 28vw;
  display: flex;
  align-items: center;
  gap: 1vw;
}

.top-left {
  justify-content: flex-start;
}

.top-right {
  justify-content: flex-end;
}

.top-center {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
}

.bt-icon,
.gear-icon {
  font-size: 26rpx;
  color: #ffffff;
}

.status-text {
  font-size: 30rpx;
  font-weight: 600;
}

.search-area {
  display: flex;
  justify-content: center;
  gap: 1vw;
  width: 100%;
}

.search-btn,
.reconnect-btn,
.disconnect-btn,
.log-clear {
  border-radius: 12rpx;
  font-size: 22rpx;
  line-height: 1.1;
  border: 1rpx solid #ffffff;
  background: #000000;
  color: #ffffff;
  padding: 0.4vh 1vw;
}

.search-btn,
.reconnect-btn {
  min-width: 16vw;
}

.search-btn[disabled],
.reconnect-btn[disabled],
.disconnect-btn[disabled] {
  opacity: 0.4;
}

.packet-area {
  width: 70vw;
  height: 20vh;
  margin: 0 auto;
  border: 1rpx solid #ffffff;
  background: #000000;
  box-sizing: border-box;
  padding: 1vh 1vw;
  display: flex;
  flex-direction: column;
  gap: 0.8vh;
  align-items: center;
  justify-content: center;
}

.device-list {
  width: 100%;
  border: 1rpx solid #ffffff;
  padding: 0.6vh 0.6vw;
  max-height: 7vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-sizing: border-box;
}

.list-title {
  font-size: 20rpx;
  color: #ffffff;
  margin-bottom: 6rpx;
  text-align: center;
}

.device-scroll {
  flex: 1;
  height: 100%;
}

.device-item {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  padding: 6rpx 8rpx;
  background: #000000;
  border: 1rpx solid #ffffff;
  margin-bottom: 6rpx;
}

.device-name {
  font-size: 20rpx;
  font-weight: 600;
  color: #ffffff;
}

.device-rssi {
  font-size: 18rpx;
  color: #ffffff;
}

.log-header {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.log-title {
  font-size: 22rpx;
  color: #ffffff;
}

.log-clear {
  padding: 0.2vh 1vw;
}

.log-list {
  width: 100%;
  flex: 1;
  min-height: 0;
  border: 1rpx solid #ffffff;
  padding: 0.4vh 0.6vw;
  box-sizing: border-box;
}

.log-item {
  display: flex;
  gap: 10rpx;
  font-size: 20rpx;
  padding: 4rpx 0;
  border-bottom: 1rpx dashed #ffffff;
}

.log-time {
  color: #ffffff;
}

.log-hex {
  color: #ffffff;
  word-break: break-all;
}

.control-area {
  width: 100%;
  height: 65vh;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 2vw;
  box-sizing: border-box;
  overflow: hidden;
  padding: 0 2vw;
}

.joystick-area {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.joystick-block {
  width: 28vw;
  border: 1rpx solid #ffffff;
  background: #000000;
  padding: 1vh 1vw;
  display: flex;
  flex-direction: column;
  gap: 1vh;
  box-sizing: border-box;
  justify-content: center;
}

.left-group {
  align-items: flex-start;
  text-align: left;
}

.right-group {
  align-items: flex-end;
  text-align: right;
}

.joystick-title {
  font-size: 22rpx;
  font-weight: 600;
  color: #ffffff;
  width: 100%;
}

.joystick {
  width: 24vh;
  height: 24vh;
  max-width: 240rpx;
  max-height: 240rpx;
  min-width: 170rpx;
  min-height: 170rpx;
  border-radius: 50%;
  background: #bfc4c9;
  border: 1rpx solid #ffffff;
  position: relative;
  overflow: hidden;
}

.stick {
  width: 35%;
  height: 35%;
  border-radius: 50%;
  background: #2b6fff;
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
}

.button-area {
  width: 32vw;
  border: 1rpx solid #ffffff;
  background: #000000;
  padding: 1vh 1vw;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 2vh;
}

.button-row {
  display: flex;
  justify-content: center;
  gap: 1.2vw;
}

.color-btn {
  width: 8.5vh;
  height: 8.5vh;
  border-radius: 50%;
  border: 1rpx solid #000000;
  color: #ffffff;
  text-align: center;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.1s ease;
}

.color-btn.pressed {
  transform: translateY(3rpx);
  filter: brightness(0.8);
}

.color-btn.red {
  background: #ff0000;
}

.color-btn.blue {
  background: #0000ff;
}

.color-btn.green {
  background: #00ff00;
}

.color-btn.yellow {
  background: #ffff00;
  color: #000000;
}

.bottom-actions {
  gap: 1vw;
}